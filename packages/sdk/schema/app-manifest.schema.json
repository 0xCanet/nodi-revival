{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nodi.community/schema/app-manifest-v1.json",
  "title": "NOD-I community app manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec", "governance"],
  "properties": {
    "apiVersion": { "const": "nodi.community/v1" },
    "kind": { "const": "App" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "version", "summary", "description", "author", "license", "repository"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?$" },
        "summary": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "author": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "url": { "type": "string", "format": "uri" }
          }
        },
        "license": { "type": "string", "minLength": 1 },
        "repository": { "type": "string", "format": "uri" },
        "homepage": { "type": "string", "format": "uri" }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["architectures", "runtime", "permissions", "resources", "healthcheck"],
      "properties": {
        "architectures": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["arm64", "amd64"] }
        },
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "composeFile", "source"],
          "properties": {
            "type": { "const": "compose" },
            "composeFile": { "type": "string", "pattern": "^(?!/)(?!.*\\.\\.).+$" },
            "source": {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "url", "ref"],
              "properties": {
                "type": { "const": "git" },
                "url": { "type": "string", "format": "uri" },
                "ref": { "type": "string", "not": { "enum": ["main", "master", "latest"] } }
              }
            }
          }
        },
        "permissions": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "bitcoin.rpc.read",
              "bitcoin.rpc.write",
              "hardware.gpio",
              "hardware.temperature.read",
              "network.inbound",
              "network.outbound",
              "storage.persistent"
            ]
          }
        },
        "resources": {
          "type": "object",
          "additionalProperties": false,
          "required": ["cpu", "memoryMb", "storageMb"],
          "properties": {
            "cpu": { "type": "number", "exclusiveMinimum": 0 },
            "memoryMb": { "type": "number", "exclusiveMinimum": 0 },
            "storageMb": { "type": "number", "exclusiveMinimum": 0 }
          }
        },
        "ui": {
          "type": "object",
          "additionalProperties": false,
          "required": ["route"],
          "properties": {
            "route": { "type": "string", "pattern": "^/" },
            "screenSummary": { "type": "boolean" }
          }
        },
        "healthcheck": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "target", "intervalSeconds"],
          "properties": {
            "type": { "enum": ["http", "command"] },
            "target": { "type": "string", "minLength": 1 },
            "intervalSeconds": { "type": "number", "exclusiveMinimum": 0 }
          }
        }
      }
    },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": { "enum": ["core", "candidate", "approved", "rejected"] },
        "proposalUrl": { "type": "string", "format": "uri" }
      }
    }
  }
}
