# NOD-I core
NODI_HTTP_PORT=8080

# Bitcoin Core RPC is reachable only inside the private Docker network.
BITCOIN_RPC_USER=nodi
BITCOIN_RPC_PASSWORD=replace-with-a-long-random-secret
# Keep `bitcoin-data` for a Docker volume or use an absolute existing datadir.
BITCOIN_DATA_PATH=bitcoin-data
BITCOIN_PRUNE_MIB=100000
BITCOIN_DBCACHE_MIB=450
BITCOIN_RPC_TIMEOUT_MS=15000

# Lottery miner is opt-in and stays disabled without a payout address.
MINER_ENABLED=false
MINER_POOL=stratum+tcp://public-pool.io:21496
MINER_ADDRESS=
MINER_WORKER=nodi
MINER_THREADS=1
MINER_CPU_LIMIT=1.0
MINER_MAX_TEMP_C=75

# Community store MVP governance.
STORE_QUORUM=5
STORE_APPROVAL_PERCENT=66
